# Base de données — PostgreSQL (Neon / Supabase), compatible Netlify
# Exemple Neon : postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"

# NextAuth
# Générer un secret : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="changez-moi-en-prod-avec-une-valeur-aleatoire"
NEXTAUTH_URL="http://localhost:3000"
# Connexion directe (non poolée) pour Prisma Migrate — sur Neon : URL sans « -pooler »
DIRECT_URL="postgresql://user:password@host/db"
