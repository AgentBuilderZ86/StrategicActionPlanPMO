// PMO NARSA — Plateforme collaborative de pilotage de la Stratégie Nationale
// de la Sécurité Routière (SNSR 2026-2030) et du plan de développement NARSA.
//
// Provider PostgreSQL (Neon/Supabase), compatible Netlify. Les colonnes
// d'énumération (statut, priorité, rôle) sont des `String` validés côté
// application via Zod (voir src/lib/constants.ts), choix conservé depuis la
// phase SQLite pour rester portable. Pour repasser en SQLite en local,
// remettre provider = "sqlite" et une DATABASE_URL "file:./dev.db".

generator client {
  provider = "prisma-client-js"
  // "native" pour le dev local ; "rhel-openssl-3.0.x" pour le runtime
  // serverless de Netlify (AWS Lambda / Amazon Linux 2023, OpenSSL 3).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id        String    @id @default(cuid())
  nom       String
  dateDebut DateTime?
  dateFin   DateTime?
  // typePmo : ECOSYSTEME (SNSR) | INTERNE (NARSA) | SI (Projets IT)
  typePmo   String    @default("INTERNE")
  // Objectif quantifié (ex: réduction mortalité %)
  objectif  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  axes      Axe[]
  pays      Pays[]
  entites   Entite[]
  actions   Action[]
  snapshots SnapshotCopil[]
}

model Axe {
  id      String   @id @default(cuid())
  nom     String
  ordre   Int      @default(0)
  planId  String
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  actions Action[]

  @@index([planId])
}

model Pays {
  id      String   @id @default(cuid())
  nom     String
  code    String?
  planId  String
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  entites Entite[]
  actions Action[]

  @@index([planId])
}

model Entite {
  id      String   @id @default(cuid())
  nom     String
  paysId  String?
  pays    Pays?    @relation(fields: [paysId], references: [id], onDelete: SetNull)
  planId  String
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  actions Action[]

  @@index([planId])
  @@index([paysId])
}

model Action {
  id          String    @id @default(cuid())
  titre       String
  description String?
  planId      String
  // Dimensions optionnelles : un nœud de niveau haut (Pilier) n'a pas
  // forcément d'axe/région/entité rattaché.
  axeId       String?
  paysId      String?
  entiteId    String?
  // Arborescence parent-enfant (auto-relation "Arbre").
  parentId    String?
  // Position dans la fratrie (sert au tri et à la codification, cf. T0.2).
  ordre       Int       @default(0)
  responsable String
  // Statut : A_LANCER | EN_COURS | TERMINE | BLOQUE
  statut      String    @default("A_LANCER")
  avancement  Int       @default(0) // 0–100
  // Priorite : HAUTE | MOYENNE | BASSE
  priorite    String    @default("MOYENNE")
  dateDebut   DateTime?
  dateFin     DateTime?
  budget      Float? // k€
  budgetConso Float? // k€
  commentaire String?
  // Niveau hiérarchique : 1=Pilier, 2=Axe, 3=Projet, 4=Action, 5=Sous-action
  niveau      Int       @default(4)
  // Codification automatique cohérente avec l'arbre (ex. PS1.CS2.PRJ1), cf. T0.2
  code        String?
  // Indicateur de performance associé (taux réduction accidents, etc.)
  indicateur  String?
  // Valeur cible de l'indicateur
  cibleIndicateur Float?
  // Valeur réalisée de l'indicateur
  valeurIndicateur Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plan       Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  axe        Axe?         @relation(fields: [axeId], references: [id], onDelete: SetNull)
  pays       Pays?        @relation(fields: [paysId], references: [id], onDelete: SetNull)
  entite     Entite?      @relation(fields: [entiteId], references: [id], onDelete: SetNull)
  parent     Action?      @relation("Arbre", fields: [parentId], references: [id], onDelete: Cascade)
  enfants    Action[]     @relation("Arbre")
  jalons     Jalon[]
  historique Avancement[]

  @@unique([planId, code])
  @@index([planId])
  @@index([axeId])
  @@index([paysId])
  @@index([entiteId])
  @@index([parentId])
}

model Jalon {
  id       String   @id @default(cuid())
  actionId String
  action   Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  titre    String
  date     DateTime
  atteint  Boolean  @default(false)

  @@index([actionId])
}

model Avancement {
  id       String   @id @default(cuid())
  actionId String
  action   Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  date     DateTime @default(now())
  valeur   Int
  statut   String

  @@index([actionId])
}

model SnapshotCopil {
  id           String   @id @default(cuid())
  planId       String
  plan         Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  periode      String // ex. "2026-06"
  faitsMarquants String?
  // Indicateurs figés (JSON sérialisé)
  indicateurs  String
  createdAt    DateTime @default(now())

  @@index([planId])
}

// ----------------------------------------------------------------------------
// Authentification (NextAuth) + rôles applicatifs
// ----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  // Role : ADMIN | PMO | CONTRIBUTEUR | LECTEUR
  role          String    @default("LECTEUR")
  // Périmètre du contributeur (ids pays/entités, JSON), null = tout le périmètre
  perimetrePays String?
  // Durcissement authentification (T0.3, exig. 37) : verrouillage de compte.
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------------------
// Piste d'audit (T0.4, exig. 33 & 35) : traçabilité des connexions et des
// écritures, avec état avant/après.
// ----------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  // Type d'événement : CREATE | UPDATE | DELETE | IMPORT | LOGIN_SUCCESS | LOGIN_FAILURE
  action    String
  // Entité concernée : Action | Axe | Pays | Entite | Plan | User | Snapshot | Auth
  entite    String
  entiteId  String?
  avant     Json?
  apres     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([entite, entiteId])
  @@index([userId])
  @@index([createdAt])
}
