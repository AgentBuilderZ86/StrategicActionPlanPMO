// PMO — Plan d'action stratégique multi-pays / multi-entités
//
// Provider SQLite en développement (imposé par le SPEC). SQLite ne supporte
// pas les `enum` natifs Prisma : les colonnes d'énumération (statut, priorité,
// rôle) sont donc des `String` dont les valeurs autorisées sont contrôlées
// côté application via Zod (voir src/lib/constants.ts). En production, le
// provider peut être basculé sur `postgresql` (Neon/Supabase) sans changer
// le code applicatif.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Plan {
  id        String    @id @default(cuid())
  nom       String
  dateDebut DateTime?
  dateFin   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  axes      Axe[]
  pays      Pays[]
  entites   Entite[]
  actions   Action[]
  snapshots SnapshotCopil[]
}

model Axe {
  id      String   @id @default(cuid())
  nom     String
  ordre   Int      @default(0)
  planId  String
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  actions Action[]

  @@index([planId])
}

model Pays {
  id      String   @id @default(cuid())
  nom     String
  code    String?
  planId  String
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  entites Entite[]
  actions Action[]

  @@index([planId])
}

model Entite {
  id      String   @id @default(cuid())
  nom     String
  paysId  String?
  pays    Pays?    @relation(fields: [paysId], references: [id], onDelete: SetNull)
  planId  String
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  actions Action[]

  @@index([planId])
  @@index([paysId])
}

model Action {
  id          String    @id @default(cuid())
  titre       String
  description String?
  planId      String
  axeId       String
  paysId      String
  entiteId    String
  responsable String
  // Statut : A_LANCER | EN_COURS | TERMINE | BLOQUE
  statut      String    @default("A_LANCER")
  avancement  Int       @default(0) // 0–100
  // Priorite : HAUTE | MOYENNE | BASSE
  priorite    String    @default("MOYENNE")
  dateDebut   DateTime?
  dateFin     DateTime?
  budget      Float? // k€
  budgetConso Float? // k€
  commentaire String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plan       Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  axe        Axe          @relation(fields: [axeId], references: [id], onDelete: Cascade)
  pays       Pays         @relation(fields: [paysId], references: [id], onDelete: Cascade)
  entite     Entite       @relation(fields: [entiteId], references: [id], onDelete: Cascade)
  jalons     Jalon[]
  historique Avancement[]

  @@index([planId])
  @@index([axeId])
  @@index([paysId])
  @@index([entiteId])
}

model Jalon {
  id       String   @id @default(cuid())
  actionId String
  action   Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  titre    String
  date     DateTime
  atteint  Boolean  @default(false)

  @@index([actionId])
}

model Avancement {
  id       String   @id @default(cuid())
  actionId String
  action   Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  date     DateTime @default(now())
  valeur   Int
  statut   String

  @@index([actionId])
}

model SnapshotCopil {
  id           String   @id @default(cuid())
  planId       String
  plan         Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  periode      String // ex. "2026-06"
  faitsMarquants String?
  // Indicateurs figés (JSON sérialisé)
  indicateurs  String
  createdAt    DateTime @default(now())

  @@index([planId])
}

// ----------------------------------------------------------------------------
// Authentification (NextAuth) + rôles applicatifs
// ----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  // Role : ADMIN | PMO | CONTRIBUTEUR | LECTEUR
  role          String    @default("LECTEUR")
  // Périmètre du contributeur (ids pays/entités, JSON), null = tout le périmètre
  perimetrePays String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
