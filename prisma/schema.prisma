// PMO NARSA — Plateforme collaborative de pilotage de la Stratégie Nationale
// de la Sécurité Routière (SNSR 2026-2030) et du plan de développement NARSA.
//
// Provider PostgreSQL (Neon/Supabase), compatible Netlify. Les colonnes
// d'énumération (statut, priorité, rôle) sont des `String` validés côté
// application via Zod (voir src/lib/constants.ts), choix conservé depuis la
// phase SQLite pour rester portable. Pour repasser en SQLite en local,
// remettre provider = "sqlite" et une DATABASE_URL "file:./dev.db".

generator client {
  provider = "prisma-client-js"
  // "native" pour le dev local ; "rhel-openssl-3.0.x" pour le runtime
  // serverless de Netlify (AWS Lambda / Amazon Linux 2023, OpenSSL 3).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Connexion directe (non poolée) requise par Prisma Migrate : le verrou
  // consultatif Postgres ne passe pas par PgBouncer (P1002 sinon). Sur Neon,
  // c'est la même URL sans le suffixe « -pooler » dans l'hôte.
  directUrl = env("DIRECT_URL")
}

model Plan {
  id        String    @id @default(cuid())
  nom       String
  dateDebut DateTime?
  dateFin   DateTime?
  // typePmo : ECOSYSTEME (SNSR) | INTERNE (NARSA) | SI (Projets IT)
  typePmo   String    @default("INTERNE")
  // Objectif quantifié (ex: réduction mortalité %)
  objectif  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  axes      Axe[]
  pays      Pays[]
  entites   Entite[]
  actions   Action[]
  snapshots SnapshotCopil[]
  alertes   Alerte[]
  populations Population[]
}

model Axe {
  id      String   @id @default(cuid())
  nom     String
  ordre   Int      @default(0)
  planId  String
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  actions Action[]

  @@index([planId])
}

model Pays {
  id      String   @id @default(cuid())
  nom     String
  code    String?
  planId  String
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  entites Entite[]
  actions Action[]

  @@index([planId])
}

model Entite {
  id      String   @id @default(cuid())
  nom     String
  paysId  String?
  pays    Pays?    @relation(fields: [paysId], references: [id], onDelete: SetNull)
  planId  String
  plan    Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  actions Action[]

  @@index([planId])
  @@index([paysId])
}

model Action {
  id          String    @id @default(cuid())
  titre       String
  description String?
  planId      String
  // Dimensions optionnelles : un nœud de niveau haut (Pilier) n'a pas
  // forcément d'axe/région/entité rattaché.
  axeId       String?
  paysId      String?
  entiteId    String?
  // Arborescence parent-enfant (auto-relation "Arbre").
  parentId    String?
  // Position dans la fratrie (sert au tri et à la codification, cf. T0.2).
  ordre       Int       @default(0)
  responsable String
  // Statut : A_LANCER | EN_COURS | TERMINE | BLOQUE
  statut      String    @default("A_LANCER")
  avancement  Int       @default(0) // 0–100
  // Priorite : HAUTE | MOYENNE | BASSE
  priorite    String    @default("MOYENNE")
  dateDebut   DateTime?
  dateFin     DateTime?
  budget      Float? // k€
  budgetConso Float? // k€
  commentaire String?
  // Niveau hiérarchique : 1=Pilier, 2=Axe, 3=Projet, 4=Action, 5=Sous-action
  niveau      Int       @default(4)
  // Codification automatique cohérente avec l'arbre (ex. PS1.CS2.PRJ1), cf. T0.2
  code        String?
  // Indicateur de performance associé (taux réduction accidents, etc.)
  indicateur  String?
  // Valeur cible de l'indicateur
  cibleIndicateur Float?
  // Valeur réalisée de l'indicateur
  valeurIndicateur Float?
  // Indice de confiance du responsable (1–5), déclaré au check-in hebdomadaire.
  confiance   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plan       Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  axe        Axe?         @relation(fields: [axeId], references: [id], onDelete: SetNull)
  pays       Pays?        @relation(fields: [paysId], references: [id], onDelete: SetNull)
  entite     Entite?      @relation(fields: [entiteId], references: [id], onDelete: SetNull)
  parent      Action?      @relation("Arbre", fields: [parentId], references: [id], onDelete: Cascade)
  enfants     Action[]     @relation("Arbre")
  jalons          Jalon[]
  historique      Avancement[]
  indicateurs      Indicateur[]
  commentaires     Commentaire[]
  attributValeurs  AttributValeur[]
  demandesValidation DemandeValidation[]
  alertes            Alerte[]

  populations ActionPopulation[]

  @@unique([planId, code])
  @@index([planId])
  @@index([axeId])
  @@index([paysId])
  @@index([entiteId])
  @@index([parentId])
}

// Indicateurs de performance multi-lignes par nœud (T1.2, exig. 11, 13, 14).
// Généralise le triplet indicateur/cible/valeur historique porté par Action.
model Indicateur {
  id       String  @id @default(cuid())
  actionId String
  action   Action  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  libelle  String
  unite    String?
  cible    Float?
  realise  Float?
  // Sens d'amélioration : HAUSSE (plus = mieux) | BAISSE (moins = mieux, ex. mortalité)
  sens     String  @default("HAUSSE")
  // Agrège-t-on cet indicateur vers les niveaux parents ? (somme sur l'arbre)
  agregeable Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actionId])
}

// Demandes de validation hiérarchique par nœud (T1.5, exig. 24, 25).
model DemandeValidation {
  id           String    @id @default(cuid())
  actionId     String
  action       Action    @relation(fields: [actionId], references: [id], onDelete: Cascade)
  demandeurId  String?
  demandeurNom String?
  // Statut : EN_ATTENTE | APPROUVE | REJETE
  statut       String    @default("EN_ATTENTE")
  // Rôle attendu du validateur (validation hiérarchique selon le niveau).
  roleValidateur String  @default("PMO")
  validateurId String?
  validateurNom String?
  commentaire  String?
  decideeAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([actionId])
  @@index([statut])
}

// Volet PMO SI / Agile (T2.3, exig. 19, 20, 21) — activé pour les plans typePmo=SI.
model Sprint {
  id        String    @id @default(cuid())
  planId    String
  nom       String
  objectif  String?
  dateDebut DateTime?
  dateFin   DateTime?
  // Statut : PLANIFIE | EN_COURS | CLOS
  statut    String    @default("PLANIFIE")
  ordre     Int       @default(0)
  createdAt DateTime  @default(now())

  items     ItemBacklog[]

  @@index([planId])
}

model ItemBacklog {
  id          String   @id @default(cuid())
  planId      String
  sprintId    String?
  sprint      Sprint?  @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  // Lien optionnel vers une action du plan.
  actionId    String?
  titre       String
  description String?
  // Colonne Kanban : BACKLOG | A_FAIRE | EN_COURS | EN_REVUE | TERMINE
  statut      String   @default("BACKLOG")
  points      Int?
  assigne     String?
  ordre       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([planId])
  @@index([sprintId])
}

// Jetons d'API pour l'interopérabilité SI externe (T2.4, exig. 36).
model ApiToken {
  id           String    @id @default(cuid())
  nom          String
  // Empreinte SHA-256 du jeton (le secret en clair n'est jamais stocké).
  tokenHash    String    @unique
  // Préfixe lisible pour identifier le jeton dans l'UI (ex. narsa_ab12…).
  prefix       String
  scopes       String    @default("read")
  createdById  String?
  dernierAcces DateTime?
  revoque      Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@index([tokenHash])
}

// Préférences de tableau de bord par utilisateur (T2.2, exig. 23).
model DashboardPref {
  id        String   @id @default(cuid())
  userId    String   @unique
  // JSON : [{ key, visible }] dans l'ordre d'affichage souhaité.
  config    String
  updatedAt DateTime @updatedAt
}

// Notifications in-app (T1.4, exig. 8, 18).
model Notification {
  id        String   @id @default(cuid())
  userId    String
  // Type : BLOCAGE | ECHEANCE | STATUT | VALIDATION | INFO
  type      String
  titre     String
  message   String?
  lien      String?
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, lu])
  @@index([createdAt])
}

// Attributs métier personnalisables par type de plan / niveau (T1.1, exig. 9,10).
model AttributDef {
  id         String   @id @default(cuid())
  // Portée : plan précis (planId) et/ou type de PMO et/ou niveau ; null = global.
  planId     String?
  typePmo    String?
  niveau     Int?
  cle        String
  libelle    String
  // Type : TEXTE | NOMBRE | DATE | BOOLEEN | LISTE
  type       String   @default("TEXTE")
  // Options d'une liste (valeurs séparées par des « ; »)
  options    String?
  obligatoire Boolean @default(false)
  ordre      Int      @default(0)
  createdAt  DateTime @default(now())

  valeurs    AttributValeur[]

  @@index([planId])
}

model AttributValeur {
  id            String      @id @default(cuid())
  actionId      String
  action        Action      @relation(fields: [actionId], references: [id], onDelete: Cascade)
  attributDefId String
  def           AttributDef @relation(fields: [attributDefId], references: [id], onDelete: Cascade)
  valeur        String?

  @@unique([actionId, attributDefId])
  @@index([actionId])
  @@index([attributDefId])
}

// Fil de commentaires collaboratif par nœud (T1.3, exig. 32).
model Commentaire {
  id        String   @id @default(cuid())
  actionId  String
  action    Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  auteurId  String?
  auteurNom String?
  contenu   String
  createdAt DateTime @default(now())

  @@index([actionId])
}

model Jalon {
  id       String   @id @default(cuid())
  actionId String
  action   Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  titre    String
  date     DateTime
  atteint  Boolean  @default(false)

  @@index([actionId])
}

model Avancement {
  id       String   @id @default(cuid())
  actionId String
  action   Action   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  date     DateTime @default(now())
  valeur   Int
  statut   String

  @@index([actionId])
}

model SnapshotCopil {
  id           String   @id @default(cuid())
  planId       String
  plan         Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  periode      String // ex. "2026-06"
  faitsMarquants String?
  // Indicateurs figés (JSON sérialisé)
  indicateurs  String
  createdAt    DateTime @default(now())

  @@index([planId])
}

// ----------------------------------------------------------------------------
// Authentification (NextAuth) + rôles applicatifs
// ----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  // Role : ADMIN | PMO | CONTRIBUTEUR | LECTEUR
  role          String    @default("LECTEUR")
  // Périmètre du contributeur (ids pays/entités, JSON), null = tout le périmètre
  perimetrePays String?
  // Habilitations fines (T1.6, exig. 30, 31)
  // Type : INTERNE | PARTENAIRE_EXTERNE
  typeUtilisateur String @default("INTERNE")
  // Droits fins (JSON { lecture, saisie, validation, reporting }) ; null = dérivés du rôle
  droits          String?
  // Durcissement authentification (T0.3, exig. 37) : verrouillage de compte.
  failedAttempts Int      @default(0)
  lockedUntil    DateTime?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------------------
// Piste d'audit (T0.4, exig. 33 & 35) : traçabilité des connexions et des
// écritures, avec état avant/après.
// ----------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  // Type d'événement : CREATE | UPDATE | DELETE | IMPORT | LOGIN_SUCCESS | LOGIN_FAILURE
  action    String
  // Entité concernée : Action | Axe | Pays | Entite | Plan | User | Snapshot | Auth
  entite    String
  entiteId  String?
  avant     Json?
  apres     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([entite, entiteId])
  @@index([userId])
  @@index([createdAt])
}

// Centre d'alertes (V1.1) : matérialisation des dérives détectées par le
// moteur de risque, avec cycle de vie de traitement. L'historique des alertes
// résolues/acceptées reste consultable et alimente le COPIL.
model Alerte {
  id       String  @id @default(cuid())
  planId   String
  actionId String
  // Statut : NOUVELLE | PRISE_EN_CHARGE | RESOLUE | ACCEPTEE
  statut   String  @default("NOUVELLE")
  score    Int
  // Niveau : CRITIQUE | ELEVE | MODERE | FAIBLE
  niveau   String
  // Facteurs explicatifs au moment du calcul (JSON [{code,label,detail,points}])
  facteurs String
  // Motif de clôture (résolution manuelle, acceptation du risque, résorption auto)
  motif    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([planId, statut])
  @@index([actionId])
}

// ---------------------------------------------------------------------------
// Module Populations & adoption (V1.2) — RGPD by design : uniquement des
// profils AGRÉGÉS de groupes de collaborateurs, jamais de donnée individuelle.
// Les pulses stockent des résultats agrégés avec seuil de k-anonymat (k >= 8).
// ---------------------------------------------------------------------------

model Population {
  id          String  @id @default(cuid())
  planId      String
  nom         String
  description String?
  // Effectif du groupe (approximatif, agrégé)
  effectif    Int     @default(0)
  // Tranche d'âge dominante : MOINS_35 | ENTRE_35_50 | PLUS_50 | MIXTE
  trancheAge  String  @default("MIXTE")
  // Ancienneté moyenne (années)
  ancienneteMoyenne Float?
  // Maturité digitale estimée (1-5)
  maturiteDigitale  Int     @default(3)
  // Exposition au changement : FAIBLE | MOYENNE | FORTE
  expositionChangement String @default("MOYENNE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan    Plan               @relation(fields: [planId], references: [id], onDelete: Cascade)
  actions ActionPopulation[]
  pulses  Pulse[]

  @@unique([planId, nom])
  @@index([planId])
}

// Lien N-N action <-> population avec niveau d'impact.
model ActionPopulation {
  id           String @id @default(cuid())
  actionId     String
  populationId String
  // Niveau d'impact : INFORME | FORME | TRANSFORME
  niveauImpact String @default("INFORME")

  action     Action     @relation(fields: [actionId], references: [id], onDelete: Cascade)
  population Population @relation(fields: [populationId], references: [id], onDelete: Cascade)

  @@unique([actionId, populationId])
  @@index([populationId])
}

// Pulse d'adoption : résultats AGRÉGÉS d'une mini-enquête (jamais de réponse
// individuelle). repondants >= 8 imposé par validation (k-anonymat).
model Pulse {
  id           String   @id @default(cuid())
  populationId String
  date         DateTime @default(now())
  // Scores agrégés 0-100
  adhesion     Int
  comprehension Int
  preparation  Int
  repondants   Int

  population Population @relation(fields: [populationId], references: [id], onDelete: Cascade)

  @@index([populationId, date])
}
